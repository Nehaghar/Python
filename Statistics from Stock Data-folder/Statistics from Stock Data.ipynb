import pandas as pd

# 1. Load the data
google_stock = pd.read_csv(r"C:\Users\Neha\Downloads\GOOG.csv")
apple_stock =  pd.read_csv(r"C:\Users\Neha\Downloads\AAPL.csv")
amazon_stock =  pd.read_csv(r"C:\Users\Neha\Downloads\AMZN.csv")

# 2. Convert 'Date' columns to datetime objects
google_stock['Date'] = pd.to_datetime(google_stock['Date'])
apple_stock['Date'] = pd.to_datetime(apple_stock['Date'])
amazon_stock['Date'] = pd.to_datetime(amazon_stock['Date'])

# 3. Set the 'Date' column as the index
google_stock.set_index('Date', inplace=True)
apple_stock.set_index('Date', inplace=True)
amazon_stock.set_index('Date', inplace=True)

# 4. Filter only the column you need and rename it
google_adj_close = google_stock[['Adj Close']].rename(columns={'Adj Close': 'Google'})
apple_adj_close = apple_stock[['Adj Close']].rename(columns={'Adj Close': 'Apple'})
amazon_adj_close = amazon_stock[['Adj Close']].rename(columns={'Adj Close': 'Amazon'})

# 5. Create the empty baseline DataFrame
dates = pd.date_range('2000-01-01', '2016-12-31')
all_stocks = pd.DataFrame(index=dates)

# 6. Join them together (they now align perfectly by the Date index)
all_stocks = all_stocks.join([google_adj_close, apple_adj_close, amazon_adj_close])
all_stocks.dropna(axis = 0,inplace=True)
print(all_stocks)
# Print the average stock price for each stock
print("--- Average Stock Price ---")
print(all_stocks.mean())
print("\n")

# Print the median stock price for each stock
print("--- Median Stock Price ---")
print(all_stocks.median())
print("\n")

# Print the standard deviation of the stock price for each stock  
print("--- Standard Deviation ---")
print(all_stocks.std())
print("\n")

# Print the correlation between stocks
print("--- Correlation Between Stocks ---")
print(all_stocks.corr())
print("\n")
# We compute the rolling mean using a 150-Day window for Google stock
rollingMean = all_stocks.rolling(150).mean()
print("--- rollingMean Between Stocks ---")
print(rollingMean.corr())
